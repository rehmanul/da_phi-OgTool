# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM APIs
# Perplexity
PERPLEXITY_API_KEY=your-perplexity-api-key-here
PERPLEXITY_MODEL=llama-3.1-sonar-small-128k-online

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flashembedding-3-large

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# Reddit API Configuration
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=OGTool/1.0 (by /u/yourusername)
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password

# LinkedIn Configuration (for scraping)
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password

# Proxy Configuration (for LinkedIn/web scraping)
PROXY_POOL_URL=http://your-proxy-service.com
PROXY_USERNAME=proxy-user
PROXY_PASSWORD=proxy-pass

# === Azure PostgreSQL (CORRECTED) ===
DATABASE_URL=postgresql://api_postgre:Justin123456@api-justin.postgres.database.azure.com:5432/postgres?sslmode=require
PGHOST=api-justin.postgres.database.azure.com
PGPORT=5432
PGUSER=api_postgre
PGDATABASE=postgres
PGPASSWORD=Justin123456
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://ogtool:ogtool_pass@rabbitmq:5672/
CLICKHOUSE_URL=http://clickhouse:8123
QDRANT_URL=http://qdrant:6333

# Monitoring
SENTRY_DSN=your-sentry-dsn
DATADOG_API_KEY=your-datadog-api-key

# Email Configuration (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# AWS Configuration (for# AWS (If needed)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=ogtool-storage

# Rate Limiting
RATE_LIMIT_REDDIT=60  # requests per minute
RATE_LIMIT_LINKEDIN=30  # requests per minute
RATE_LIMIT_OPENAI=3500  # tokens per minute

# Feature Flags
ENABLE_AUTO_POSTING=false
ENABLE_CHATGPT_TRACKING=true
ENABLE_LINKEDIN_SCRAPING=true

# Cost Limits (per organization per month)
COST_LIMIT_STARTER=100
COST_LIMIT_GROWTH=500
COST_LIMIT_ENTERPRISE=5000
